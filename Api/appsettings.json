{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=printit;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "PrintIt",
    "Audience": "PrintIt.Admin",
    "SigningKey": "change-this-dev-signing-key-at-least-32-characters-long",
    "AccessTokenMinutes": 120
  },
  "AuthCookie": {
    "Name": "printit_admin_auth",
    "Path": "/",
    "HttpOnly": true,
    "IsEssential": true,
    "SameSite": "Lax",
    "Secure": false
  },
  "AdminBootstrap": {
    "Email": "admin@printit.local",
    "Password": "Admin123!"
  },
  "StoreBootstrap": {
    "Name": "PrintIt Default Store",
    "Slug": "default-store"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
